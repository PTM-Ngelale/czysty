# Copy this file to .env.local and fill in your values

# Resend — for sending booking and registration emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email to receive lead notifications (defaults to info.czysty@gmail.com)
NOTIFICATION_EMAIL=info.czysty@gmail.com

# Secret token embedded in the QR code URL — set to any random string
# Anyone without this exact token in the URL will be redirected to /
QR_SECRET=czysty2026launch

# Your production domain (used to generate the QR code URL on /admin/qr)
# Change to your real domain before printing QR codes
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Flutterwave — payment processing at checkout
# Public key is safe to expose to the browser; secret key must stay server-only
# and is required to verify payments (get both from the Flutterwave dashboard)
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
# Not used by the current inline-checkout + verify flow; kept for future direct-charge APIs
FLUTTERWAVE_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
